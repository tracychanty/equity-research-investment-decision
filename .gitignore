# ── Data files ─────────────────────────────────────────────────
Data/
*.csv
*.pkl
*.sqlite
*.db

# ── Output files ───────────────────────────────────────────────
# Outputs/ is needed by the deployed dashboard (app.py reads specific CSVs from here).
# Ignore everything in Outputs/ by default, then re-include just the phase folders
# and the CSVs directly inside them. Anything else in there (e.g. event_study/plots/*.png)
# stays ignored — app.py rebuilds charts in Plotly, it doesn't load those images.
Outputs/*
!Outputs/*/
!Outputs/*/*.csv

*.png
*.jpg
*.jpeg
!assets/logo.png

# ── Jupyter notebooks checkpoints ──────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── Virtual environments ────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

